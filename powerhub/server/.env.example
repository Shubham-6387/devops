# PowerHub Backend — Environment Variables
# Copy this file to .env and fill in your values

PORT=5000

# MongoDB connection URI
# Local:   mongodb://localhost:27017/powerhub
# Docker:  mongodb://dbadmin:SuperSecurePassword123@mongodb:27017/powerhub?authSource=admin
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/powerhub
MONGO_URI=mongodb://localhost:27017/powerhub

# JWT signing secret — use a strong random string in production
JWT_SECRET=change_me_to_a_strong_secret

# OpenFoodFacts API base URL (no trailing slash)
FOOD_API_BASE=https://world.openfoodfacts.org
